{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "Normalized video metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "channelId": { "type": "string" },
        "speakerIds": { "type": "array", "items": { "type": "string" } },
        "uploadDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] }
      },
      "required": ["title", "channelId", "status"]
    },
    "Channel": {
      "title": "Channel",
      "description": "YouTube channel metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["name"]
    },
    "Speaker": {
      "title": "Speaker",
      "description": "Speaker metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "VideoChunk": {
      "title": "VideoChunk",
      "description": "Chunked transcript segments",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "text": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" }
      },
      "required": ["videoId", "text", "startTime", "endTime"]
    },
    "QuranVerse": {
      "title": "QuranVerse",
      "description": "Full Quran dataset",
      "type": "object",
      "properties": {
        "surah": { "type": "number" },
        "ayah": { "type": "number" },
        "text_uthmani": { "type": "string" },
        "text_simple_ar": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["surah", "ayah", "text_uthmani"]
    },
    "Hadith": {
      "title": "Hadith",
      "description": "Canonical hadith corpus",
      "type": "object",
      "properties": {
        "text_ar": { "type": "string" },
        "text_en": { "type": "string" },
        "narrator_en": { "type": "string" },
        "collection": { "type": "string" }
      },
      "required": ["text_ar", "text_en", "collection"]
    },
    "Topic": {
      "title": "Topic",
      "description": "Hierarchical topic taxonomy",
      "type": "object",
      "properties": {
        "name_en": { "type": "string" },
        "name_ar": { "type": "string" },
        "parentId": { "type": "string" },
        "level": { "type": "number" }
      },
      "required": ["name_en", "name_ar"]
    },
    "QuranReferenceDetection": {
      "title": "QuranReferenceDetection",
      "description": "AI-detected Quran citations",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "verseId": { "type": "string" },
        "confidenceScore": { "type": "number" }
      },
      "required": ["videoId", "verseId", "confidenceScore"]
    }
  },
  "firestore": {
    "/videos/{videoId}": { "schema": "Video", "description": "Normalized video metadata" },
    "/channels/{channelId}": { "schema": "Channel", "description": "YouTube channel metadata" },
    "/speakers/{speakerId}": { "schema": "Speaker", "description": "Speaker metadata" },
    "/video_chunks/{chunkId}": { "schema": "VideoChunk", "description": "Chunked transcript segments" },
    "/quran_verses/{verseId}": { "schema": "QuranVerse", "description": "Full Quran dataset" },
    "/hadith_texts/{hadithId}": { "schema": "Hadith", "description": "Canonical hadith corpus" },
    "/topics/{topicId}": { "schema": "Topic", "description": "Hierarchical topic taxonomy" },
    "/quran_reference_detections/{detectionId}": { "schema": "QuranReferenceDetection", "description": "AI-detected Quran citations" }
  }
}
