{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "Metadata and analysis for an indexed YouTube video",
      "type": "object",
      "properties": {
        "youtube_id": { "type": "string", "description": "YouTube Video ID" },
        "title": { "type": "string", "description": "Video Title" },
        "url": { "type": "string", "description": "Full YouTube URL" },
        "executive_summary": { "type": "string", "description": "AI-generated executive summary" },
        "linkable_timestamps": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "time": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "themes_and_topics": {
          "type": "object",
          "properties": {
            "overarching_message": { "type": "string" },
            "categories": { "type": "array", "items": { "type": "string" } }
          }
        },
        "theological_topics": { "type": "array", "items": { "type": "string" } },
        "key_points": { "type": "array", "items": { "type": "string" }, "description": "List of key points" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "SEO tags" },
        "minute_by_minute": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "transcript": { "type": "string" },
        "scripture_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference_type": { "type": "string" },
              "reference": { "type": "string" }
            }
          }
        },
        "entities": { "type": "array", "items": { "type": "string" } },
        "arguments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "claim": { "type": "string" },
              "speaker": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "debate_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": { "type": "string" },
              "speaker": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "speaker_name": { "type": "string" },
        "channel_name": { "type": "string" },
        "channel_url": { "type": "string" },
        "official_description": { "type": "string", "description": "Full YouTube video description" },
        "upload_date": { "type": "string", "description": "Video upload date from YouTube" },
        "video_timestamp": { "type": "string" },
        "token_count": { "type": "number" },
        "all_scripture_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference_type": { "type": "string" },
              "reference_key": { "type": "string" },
              "evidence_text": { "type": "string" },
              "confidence_score": { "type": "number" },
              "topic_tags": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "userId": { "type": "string", "description": "Owner's Firebase Auth UID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["youtube_id", "title", "url", "userId", "createdAt"]
    },
    "Segment": {
      "title": "Segment",
      "description": "A specific topic segment within a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string", "description": "Reference to the Video document ID" },
        "topic": { "type": "string" },
        "start_time": { "type": "number" },
        "end_time": { "type": "number" },
        "summary": { "type": "string" }
      },
      "required": ["videoId", "topic", "start_time", "end_time", "summary"]
    },
    "VideoReference": {
      "title": "VideoReference",
      "description": "A linked scripture or knowledge reference within a video",
      "type": "object",
      "properties": {
        "video_id": { "type": "string" },
        "reference_type": { "type": "string", "enum": ["quran", "hadith", "bible"] },
        "reference_key": { "type": "string", "description": "Normalized key (e.g. Q_2_256)" },
        "matched_text": { "type": "string" },
        "confidence_score": { "type": "number" },
        "start_time": { "type": "number" },
        "end_time": { "type": "number" },
        "topic_tags": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["video_id", "reference_type", "reference_key", "matched_text", "confidence_score", "userId", "createdAt"]
    },
    "KnowledgeTopic": {
      "title": "KnowledgeTopic",
      "description": "A unified topic aggregating insights from multiple sources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "related_scriptures": { "type": "array", "items": { "type": "string" } },
        "cross_faith_comparisons": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "userId", "createdAt"]
    },
    "KnowledgeEntry": {
      "title": "KnowledgeEntry",
      "description": "An individual piece of information contributing to a KnowledgeTopic",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "sourceType": { "type": "string", "enum": ["video", "text", "scripture"] },
        "sourceId": { "type": "string" },
        "content": { "type": "string" },
        "speaker": { "type": "string" },
        "timestamp": { "type": "number" },
        "metadata": { "type": "object" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["topicId", "sourceType", "content", "userId", "createdAt"]
    },
    "Taxonomy": {
      "title": "Taxonomy",
      "description": "Consistent categorization system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["topic", "theme", "argument_type", "category"] },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "type", "userId"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of indexed videos"
    },
    "/videos/{videoId}/segments/{segmentId}": {
      "schema": "Segment",
      "description": "Sub-collection of segments for a specific video"
    },
    "/video_references/{referenceId}": {
      "schema": "VideoReference",
      "description": "Root collection of all scripture and knowledge references across all videos"
    },
    "/knowledge_topics/{topicId}": {
      "schema": "KnowledgeTopic",
      "description": "Unified knowledge base topics"
    },
    "/knowledge_entries/{entryId}": {
      "schema": "KnowledgeEntry",
      "description": "Individual entries linked to topics"
    },
    "/taxonomy/{taxonomyId}": {
      "schema": "Taxonomy",
      "description": "Categorization system"
    }
  }
}
