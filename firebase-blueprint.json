{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "Metadata and analysis for an indexed YouTube video",
      "type": "object",
      "properties": {
        "youtube_id": { "type": "string", "description": "YouTube Video ID" },
        "title": { "type": "string", "description": "Video Title" },
        "url": { "type": "string", "description": "Full YouTube URL" },
        "executive_summary": { "type": "string", "description": "AI-generated executive summary" },
        "linkable_timestamps": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "time": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "themes_and_topics": {
          "type": "object",
          "properties": {
            "overarching_message": { "type": "string" },
            "categories": { "type": "array", "items": { "type": "string" } }
          }
        },
        "theological_topics": { "type": "array", "items": { "type": "string" } },
        "key_points": { "type": "array", "items": { "type": "string" }, "description": "List of key points" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "SEO tags" },
        "minute_by_minute": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "transcript": { "type": "string" },
        "scripture_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference_type": { "type": "string" },
              "reference": { "type": "string" }
            }
          }
        },
        "entities": { "type": "array", "items": { "type": "string" } },
        "arguments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "claim": { "type": "string" },
              "speaker": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "debate_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": { "type": "string" },
              "speaker": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        },
        "speaker_name": { "type": "string" },
        "channel_name": { "type": "string" },
        "channel_url": { "type": "string" },
        "official_description": { "type": "string", "description": "Full YouTube video description" },
        "upload_date": { "type": "string", "description": "Video upload date from YouTube" },
        "video_timestamp": { "type": "string" },
        "token_count": { "type": "number" },
        "all_scripture_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference_type": { "type": "string" },
              "reference_key": { "type": "string" },
              "evidence_text": { "type": "string" },
              "confidence_score": { "type": "number" },
              "topic_tags": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "userId": { "type": "string", "description": "Owner's Firebase Auth UID" },
        "createdAt": { "type": "string", "format": "date-time" },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" }
      },
      "required": ["youtube_id", "title", "url", "userId", "createdAt"]
    },
    "Segment": {
      "title": "Segment",
      "description": "A specific topic segment within a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string", "description": "Reference to the Video document ID" },
        "topic": { "type": "string" },
        "start_time": { "type": "number" },
        "end_time": { "type": "number" },
        "summary": { "type": "string" }
      },
      "required": ["videoId", "topic", "start_time", "end_time", "summary"]
    },
    "QuranVerse": {
      "title": "QuranVerse",
      "description": "A single verse from the Quran",
      "type": "object",
      "properties": {
        "surah_number": { "type": "number" },
        "surah_name_en": { "type": "string" },
        "surah_name_ar": { "type": "string" },
        "ayah_number": { "type": "number" },
        "text_ar": { "type": "string" },
        "text_en": { "type": "string" },
        "normalized_text": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "revelation_type": { "type": "string", "enum": ["Meccan", "Medinan"] },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" }
      },
      "required": ["surah_number", "ayah_number", "text_ar", "text_en"]
    },
    "BibleVerse": {
      "title": "BibleVerse",
      "description": "A single verse from the Bible",
      "type": "object",
      "properties": {
        "book": { "type": "string" },
        "chapter": { "type": "number" },
        "verse": { "type": "number" },
        "text_en": { "type": "string" },
        "normalized_text": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" }
      },
      "required": ["book", "chapter", "verse", "text_en"]
    },
    "ScriptureUsage": {
      "title": "ScriptureUsage",
      "description": "Auto-linked scripture usage in videos",
      "type": "object",
      "properties": {
        "video_id": { "type": "string" },
        "timestamp": { "type": "number" },
        "scripture_id": { "type": "string" },
        "context": { "type": "string" },
        "confidence_score": { "type": "number" }
      },
      "required": ["video_id", "scripture_id"]
    },
    "Hadith": {
      "title": "Hadith",
      "description": "Authenticated Hadith record",
      "type": "object",
      "properties": {
        "source_collection": { "type": "string" },
        "source_short": { "type": "string" },
        "book_name_en": { "type": "string" },
        "chapter_name_en": { "type": "string" },
        "hadith_number": { "type": "string" },
        "text_ar": { "type": "string" },
        "text_en": { "type": "string" },
        "grade": { "type": "string", "enum": ["Sahih", "Hasan", "Daif", "Other"] },
        "topics": { "type": "array", "items": { "type": "string" } },
        "narrator": { "type": "string" },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" },
        "generated_by_ai": { "type": "boolean" }
      },
      "required": ["source_collection", "hadith_number", "text_ar", "text_en", "grade"]
    },
    "HadithUsage": {
      "title": "HadithUsage",
      "description": "Auto-linked Hadith usage in videos",
      "type": "object",
      "properties": {
        "video_id": { "type": "string" },
        "timestamp": { "type": "number" },
        "hadith_id": { "type": "string" },
        "detected_text": { "type": "string" },
        "match_type": { "type": "string", "enum": ["exact", "approximate", "topic_level"] },
        "confidence_score": { "type": "number" }
      },
      "required": ["video_id", "hadith_id", "confidence_score"]
    },
    "KnowledgeBaseEntry": {
      "title": "KnowledgeBaseEntry",
      "description": "A structured knowledge base entry",
      "type": "object",
      "properties": {
        "title_en": { "type": "string" },
        "title_ar": { "type": "string" },
        "type": { "type": "string", "enum": ["topic", "concept", "question"] },
        "content_en": { "type": "string" },
        "content_ar": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "keywords_en": { "type": "array", "items": { "type": "string" } },
        "keywords_ar": { "type": "array", "items": { "type": "string" } },
        "related_quran": { "type": "array", "items": { "type": "string" } },
        "related_bible": { "type": "array", "items": { "type": "string" } },
        "related_hadith": { "type": "array", "items": { "type": "string" } },
        "related_videos": { "type": "array", "items": { "type": "string" } },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" }
      },
      "required": ["title_en", "type", "content_en"]
    },
    "RefutationEntry": {
      "title": "RefutationEntry",
      "description": "Structured misconception/claim refutation",
      "type": "object",
      "properties": {
        "claim_en": { "type": "string" },
        "claim_ar": { "type": "string" },
        "claim_type": { "type": "string", "enum": ["misconception", "polemical", "comparative", "doctrinal"] },
        "response_summary_en": { "type": "string" },
        "response_summary_ar": { "type": "string" },
        "detailed_response_en": { "type": "string" },
        "detailed_response_ar": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "related_quran": { "type": "array", "items": { "type": "string" } },
        "related_hadith": { "type": "array", "items": { "type": "string" } },
        "related_bible": { "type": "array", "items": { "type": "string" } },
        "review_status": { "type": "string", "enum": ["draft", "reviewed", "approved", "rejected", "needs_revision"] },
        "version_history": { "type": "array", "items": { "type": "object" } },
        "last_updated_by": { "type": "string" }
      },
      "required": ["claim_en", "claim_type", "response_summary_en", "detailed_response_en"]
    },
      "description": "A linked scripture or knowledge reference within a video",
      "type": "object",
      "properties": {
        "video_id": { "type": "string" },
        "reference_type": { "type": "string", "enum": ["quran", "hadith", "bible"] },
        "reference_key": { "type": "string", "description": "Normalized key (e.g. Q_2_256)" },
        "matched_text": { "type": "string" },
        "confidence_score": { "type": "number" },
        "start_time": { "type": "number" },
        "end_time": { "type": "number" },
        "topic_tags": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["video_id", "reference_type", "reference_key", "matched_text", "confidence_score", "userId", "createdAt"]
    },
    "KnowledgeTopic": {
      "title": "KnowledgeTopic",
      "description": "A unified topic aggregating insights from multiple sources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "related_scriptures": { "type": "array", "items": { "type": "string" } },
        "cross_faith_comparisons": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "userId", "createdAt"]
    },
    "KnowledgeEntry": {
      "title": "KnowledgeEntry",
      "description": "An individual piece of information contributing to a KnowledgeTopic",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "sourceType": { "type": "string", "enum": ["video", "text", "scripture"] },
        "sourceId": { "type": "string" },
        "content": { "type": "string" },
        "speaker": { "type": "string" },
        "timestamp": { "type": "number" },
        "metadata": { "type": "object" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["topicId", "sourceType", "content", "userId", "createdAt"]
    },
    "ReviewQueue": {
      "title": "ReviewQueue",
      "description": "Queue for content review",
      "type": "object",
      "properties": {
        "content_type": { "type": "string", "enum": ["quran_link", "hadith_link", "knowledge_entry", "refutation", "scripture_usage", "topic_page"] },
        "content_id": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "reason": { "type": "string", "enum": ["new_ai_generated", "low_confidence", "doctrinal_sensitive", "flagged_by_user", "needs_update"] },
        "status": { "type": "string", "enum": ["pending", "in_review", "approved", "rejected", "needs_revision"] },
        "assigned_to": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["content_type", "content_id", "priority", "status", "created_at"]
    },
    "ReviewLog": {
      "title": "ReviewLog",
      "description": "Log of review actions",
      "type": "object",
      "properties": {
        "content_id": { "type": "string" },
        "reviewer_name": { "type": "string" },
        "review_action": { "type": "string", "enum": ["approved", "rejected", "edited", "commented"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content_id", "reviewer_name", "review_action", "timestamp"]
    },
    "Taxonomy": {
      "title": "Taxonomy",
      "description": "Consistent categorization system",
      "type": "object",
      "properties": {
        "canonical_name_en": { "type": "string" },
        "canonical_name_ar": { "type": "string" },
        "aliases_en": { "type": "array", "items": { "type": "string" } },
        "aliases_ar": { "type": "array", "items": { "type": "string" } },
        "parent_topic": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "merged", "deprecated"] }
      },
      "required": ["canonical_name_en", "canonical_name_ar", "status"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of indexed videos"
    },
    "/videos/{videoId}/segments/{segmentId}": {
      "schema": "Segment",
      "description": "Sub-collection of segments for a specific video"
    },
    "/quran_collection/{verseId}": {
      "schema": "QuranVerse",
      "description": "Full Quran dataset"
    },
    "/bible_collection/{verseId}": {
      "schema": "BibleVerse",
      "description": "Full Bible dataset"
    },
    "/scripture_usage/{usageId}": {
      "schema": "ScriptureUsage",
      "description": "Auto-linked scripture usage in videos"
    },
    "/knowledge_base/{entryId}": {
      "schema": "KnowledgeBaseEntry",
      "description": "Structured knowledge base entries"
    },
    "/video_references/{referenceId}": {
      "schema": "VideoReference",
      "description": "Root collection of all scripture and knowledge references across all videos"
    },
    "/hadith_collection/{hadithId}": {
      "schema": "Hadith",
      "description": "Authenticated Hadith dataset"
    },
    "/hadith_usage/{usageId}": {
      "schema": "HadithUsage",
      "description": "Auto-linked Hadith usage in videos"
    },
    "/refutation_entries/{refutationId}": {
      "schema": "RefutationEntry",
      "description": "Structured misconception/claim refutation"
    },
    "/review_queue/{reviewId}": {
      "schema": "ReviewQueue",
      "description": "Queue for content review"
    },
    "/review_log/{logId}": {
      "schema": "ReviewLog",
      "description": "Log of review actions"
    },
    "/taxonomy/{taxonomyId}": {
      "schema": "Taxonomy",
      "description": "Consistent categorization system"
    },
    "/topic_video_map/{mapId}": {
      "schema": "TopicVideoMap",
      "description": "Mapping between topics and videos"
    }
  }
}
